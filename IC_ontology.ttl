###  https://plasma-mds.org/ontology/IC_Ontology/IC_C0004
ic:IC_C0004 rdf:type owl:Class ;
            owl:equivalentClass [ owl:intersectionOf ( ic:IC_C0001
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty plsmo:PLSMO_R0010 ;
                                                         owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                         owl:onClass ic:IC_C0058
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ;
            rdfs:subClassOf ic:IC_C0001 ;
            chmo:IAO_0000115 "Settings for the eluent generator."@en ;
            dcterms:references <http://purl.allotrope.org/ontologies/role#AFRL_0000220> ;
            rdfs:label "Eluent Generator Settings"@en .


###  https://plasma-mds.org/ontology/IC_Ontology/IC_C0005
ic:IC_C0005 rdf:type owl:Class ;
            rdfs:subClassOf ic:IC_C0004 ;
            chmo:IAO_0000115 "States the used cartridge, which is used to generate the eluent from. The name of the cartidge contains the chemical substance which mades up the eluent."@en ;
            dcterms:references <http://purl.allotrope.org/ontologies/role#AFRL_0000220> ;
            rdfs:label "Eluent Cartridge"@en .


###  https://plasma-mds.org/ontology/IC_Ontology/IC_C0006
ic:IC_C0006 rdf:type owl:Class ;
            rdfs:subClassOf ic:IC_C0004 ;
            chmo:IAO_0000115 "Determines whether the generated eluent is produced isocratic (one constant concentration for the entire measurement) or gradiant wise (changing concentration over the course of the measurement)."@en ;
            dcterms:references <http://purl.allotrope.org/ontologies/role#AFRL_0000220> ;
            rdfs:label "Eluent Mode"@en .


###  https://plasma-mds.org/ontology/IC_Ontology/IC_C0007
