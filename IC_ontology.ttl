                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ;
            rdfs:subClassOf ic:IC_C0001 ;
            chmo:IAO_0000115 "Settings for the pump unit of the device."@en ;
            rdfs:label "Pump Settings"@en .


###  https://plasma-mds.org/ontology/IC_Ontology/IC_C0008
ic:IC_C0008 rdf:type owl:Class ;
            rdfs:subClassOf ic:IC_C0007 ;
            chmo:IAO_0000115 "Defines the systemwise mixture of different eluent components. In case of an isocratic pump mode, there is only one eluent channel. In case of gradient pump mode, the amount of possible different components for the eluent mixture are system dependent."@en ;
            dcterms:references <http://purl.allotrope.org/ontologies/role#AFRL_0000220> ;
            rdfs:label "Eluent Channels"@en .


###  https://plasma-mds.org/ontology/IC_Ontology/IC_C0009
ic:IC_C0009 rdf:type owl:Class ;
            rdfs:subClassOf ic:IC_C0007 ;
            chmo:IAO_0000115 "The mode at which the pump of the device is operated. The mode can either be 'isocratic' or 'gradient'."@en ;
            rdfs:label "Pump Mode"@en .


