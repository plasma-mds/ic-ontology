#################################################################
#    Classes
#################################################################

###  http://purl.allotrope.org/ontologies/result#AFR_0000413
AFO:AFR_0000413 rdf:type owl:Class ;
                rdfs:subClassOf ic:IC_C0025 ;
                chmo:IAO_0000115 "A peak is a data region containing a single local extremum in the dependent variable of the distribution function. [Allotrope]"@en ;
                rdfs:label "Peak"@en .


###  http://purl.allotrope.org/ontologies/result#AFR_0000948
AFO:AFR_0000948 rdf:type owl:Class ;
                rdfs:subClassOf ic:IC_C0025 ;
                chmo:IAO_0000115 "A peak facet that denotes the ordinate value of the peak extremum offset by the baseline ascribed to the peak. [Allotrope]"@en ;
                dcterms:references AFO:AFR_0000413 ,
                                   AFO:AFR_0001219 ;
                rdfs:label "Peak Height"@en .


###  http://purl.allotrope.org/ontologies/result#AFR_0001073
AFO:AFR_0001073 rdf:type owl:Class ;
                rdfs:subClassOf ic:IC_C0025 ;
                chmo:IAO_0000115 "A peak facet that quantitates the area enclosed by a peak and the selected baseline. [Allotrope]"@en ;
                dcterms:references AFO:AFR_0000413 ,
                                   AFO:AFR_0001219 ;
                rdfs:label "Peak Area"@en .


###  http://purl.allotrope.org/ontologies/result#AFR_0001075
AFO:AFR_0001075 rdf:type owl:Class ;
                rdfs:subClassOf ic:IC_C0025 ;
                chmo:IAO_0000115 "A peak facet denoting its width at a specified peak height or variance. [Allotrope]"@en ;
                dcterms:references AFO:AFR_0000413 ,
                                   AFO:AFR_0000948 ;
                rdfs:label "Peak Width"@en .


###  http://purl.allotrope.org/ontologies/result#AFR_0001219
AFO:AFR_0001219 rdf:type owl:Class ;
                rdfs:subClassOf ic:IC_C0025 ;
                chmo:IAO_0000115 "An information content entity that describes the background (offset) component of a signal not due to the analyte (peak) of interest. [Allotrope]"@en ;
                rdfs:label "Baseline"@en .


###  http://purl.allotrope.org/ontologies/result#AFR_0001267
AFO:AFR_0001267 rdf:type owl:Class ;
                rdfs:subClassOf QUDT:Quantity ;
                chmo:IAO_0000115 "An autosampler parameter specification that specifies the volume of sample the autosampler is to inject into the mobile phase for separation. [Allotrope]"@en ;
                dcterms:references <http://purl.allotrope.org/ontologies/role#AFRL_0000011> ;
                rdfs:label "Autosampler Injection Volume Setting"@en .


###  http://purl.allotrope.org/ontologies/result#AFR_0001538
AFO:AFR_0001538 rdf:type owl:Class ;
                rdfs:subClassOf QUDT:Quantity ;
                chmo:IAO_0000115 "An autosampler temperature setting is a setting that sets the temperature within the autosampler. [Allotrope]"@en ;
                rdfs:label "Autosampler Temperature Setting"@en .


###  http://purl.allotrope.org/ontologies/result#AFR_0002029
AFO:AFR_0002029 rdf:type owl:Class ;
                rdfs:subClassOf QUDT:Quantity ;
                chmo:IAO_0000115 "A chromatography column length (datum) is a length datum that quantifies the length of a chromatography column. [Allotrope]"@en ;
                rdfs:label "Chromatography Column Length"@en .


###  http://purl.allotrope.org/ontologies/result#AFR_0002561
AFO:AFR_0002561 rdf:type owl:Class ;
                rdfs:subClassOf QUDT:Quantity ;
                chmo:IAO_0000115 "A chromatography column particle size is a particle size datum that quantifies the dimensions of packing particles in a chromatography column. [Allotrope]"@en ;
                rdfs:label "Chromatography Column Particle size"@en .


###  http://purl.allotrope.org/ontologies/result#AFR_0002773
AFO:AFR_0002773 rdf:type owl:Class ;
                rdfs:subClassOf QUDT:Quantity ;
                chmo:IAO_0000115 "A column compartment temperature setting is a temperature setting that specifies the temperature of some column compartment. [Allotrope]"@en ;
                rdfs:label "Column Compartment Temperature Setting"@en .


###  http://purl.allotrope.org/ontologies/role#AFRL_0000011
<http://purl.allotrope.org/ontologies/role#AFRL_0000011> rdf:type owl:Class ;
                                                         rdfs:subClassOf ic:IC_C0025 ;
                                                         chmo:IAO_0000115 "Mobile phase is the chromatographic phase role of a fluid material entity in a chromatography process to act as the fluid that percolates through or along the stationary bed in chromatography. [Allotrope, CHMO]"@en ;
                                                         rdfs:label "Mobile Phase"@en .


###  http://purl.allotrope.org/ontologies/role#AFRL_0000032
<http://purl.allotrope.org/ontologies/role#AFRL_0000032> rdf:type owl:Class ;
                                                         rdfs:subClassOf ic:IC_C0025 ;
                                                         chmo:IAO_0000115 "A stationary phase is the chromatographic phase role of a solid, gel or liquid material that is the stationary component in chromatography. [Allotrope]"@en ;
                                                         rdfs:label "Stationary Phase"@en .


###  http://purl.allotrope.org/ontologies/role#AFRL_0000220
<http://purl.allotrope.org/ontologies/role#AFRL_0000220> rdf:type owl:Class ;
                                                         rdfs:subClassOf <http://purl.allotrope.org/ontologies/role#AFRL_0000011> ;
                                                         chmo:IAO_0000115 "Eluent is a mobile phase entering a column to perform a separation of material. [Allotrope]"@en ;
                                                         rdfs:label "Eluent"@en .


###  http://purl.obolibrary.org/obo/CHMO_0001000
chmo:CHMO_0001000 rdf:type owl:Class ;
                  rdfs:subClassOf ic:IC_C0018 ;
                  chmo:IAO_0000115 "A separation method where the components are distributed between two phases, one of which is stationary, while the other moves in a definite direction."@en ;
                  rdfs:label "Chromatography"@en .


###  http://purl.obolibrary.org/obo/CHMO_0001001
chmo:CHMO_0001001 rdf:type owl:Class ;
                  rdfs:subClassOf chmo:CHMO_0001000 ;
                  chmo:IAO_0000115 "A chromatography method where the stationary bed is within a tube (of standard length 25 cm). The particles of the solid stationary phase or support coated with a liquid stationary phase may fill the whole inside volume of the tube (packed column) or be concentrated on or along the inside tube wall leaving an open, unrestricted path for the mobile phase in the middle part of the tube (open-tubular column)."@en ;
                  rdfs:label "Column Chromatography"@en .


###  http://purl.obolibrary.org/obo/CHMO_0001012
chmo:CHMO_0001012 rdf:type owl:Class ;
                  rdfs:subClassOf ic:IC_C0019 ;
                  chmo:IAO_0000115 "Column chromatography where the separation is caused by differences in charge, the mobile phase is aqueous and the analyte is ionic."@en ;
                  dcterms:references <http://purl.allotrope.org/ontologies/role#AFRL_0000011> ;
                  rdfs:label "Ion Exclusion Chromatography"@en .


###  http://purl.obolibrary.org/obo/CHMO_0001014
chmo:CHMO_0001014 rdf:type owl:Class ;
                  rdfs:subClassOf ic:IC_C0019 ;
                  chmo:IAO_0000115 "Column chromatography where the separation is caused by differences in ion-exchange affinity."@en ;
                  rdfs:label "Ion-exchange Chromatography"@en .


###  http://purl.obolibrary.org/obo/CHMO_0001128
chmo:CHMO_0001128 rdf:type owl:Class ;
                  rdfs:subClassOf ic:IC_C0019 ;
                  chmo:IAO_0000115 "Chromatography in which separation is based mainly on differences between the adsorption affinities of the sample components for the surface of an active solid."@en ;
                  rdfs:label "Adsorption Chromatography"@en .


###  http://purl.obolibrary.org/obo/CHMO_0001209
chmo:CHMO_0001209 rdf:type owl:Class ;
                  owl:equivalentClass [ owl:intersectionOf ( chmo:CHMO_0001014
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty plsmo:PLSMO_R0042 ;
                                                               owl:someValuesFrom ic:IC_C0013
                                                             ]
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty plsmo:PLSMO_R0042 ;
                                                               owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                               owl:onClass ic:IC_C0001
                                                             ]
                                                           ) ;
                                        rdf:type owl:Class
                                      ] ;
                  rdfs:subClassOf chmo:CHMO_0001014 ;
                  chmo:IAO_0000115 "Column chromatography where anions are retained by positively charged functional groups in the stationary phase."@en ;
                  rdfs:label "Anion-exchange Chromatography"@en .


###  http://purl.obolibrary.org/obo/CHMO_0001210
chmo:CHMO_0001210 rdf:type owl:Class ;
                  owl:equivalentClass [ owl:intersectionOf ( chmo:CHMO_0001014
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty plsmo:PLSMO_R0042 ;
                                                               owl:someValuesFrom ic:IC_C0013
                                                             ]
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty plsmo:PLSMO_R0042 ;
                                                               owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                               owl:onClass ic:IC_C0001
                                                             ]
                                                           ) ;
                                        rdf:type owl:Class
                                      ] ;
                  rdfs:subClassOf chmo:CHMO_0001014 ;
                  chmo:IAO_0000115 "Column chromatography where cations are retained by negatively charged functional groups in the stationary phase."@en ;
                  rdfs:label "Cation-exchange Chromatography"@en .


###  http://purl.obolibrary.org/obo/CHMO_0002280
chmo:CHMO_0002280 rdf:type owl:Class ;
                  rdfs:subClassOf chmo:CHMO_0001014 ;
                  chmo:IAO_0000115 "A type of column chromatography in which ions in solution can be 'paired' or neutralised and separated as an ion pair on a reversed-phase column. Ion-pairing agents are usually ionic compounds that contain a hydrocarbon chain."@en ;
                  rdfs:label "Ion Pair Chromatography"@en .


###  http://purl.obolibrary.org/obo/CHMO_0002403
chmo:CHMO_0002403 rdf:type owl:Class ;
                  rdfs:subClassOf ic:IC_C0019 ;
                  chmo:IAO_0000115 "Chromatography in which separation is based mainly on differences between the solubility of the sample components in the stationary phase (gas chromatography), or on differences between the solubilities of the components in the mobile and stationary phases (liquid chromatography)."@en ;
                  dcterms:references <http://purl.allotrope.org/ontologies/role#AFRL_0000011> ,
                                     <http://purl.allotrope.org/ontologies/role#AFRL_0000032> ;
                  rdfs:label "Partition Chromatography"@en .


###  http://qudt.org/schema/qudt/Quantity
QUDT:Quantity rdf:type owl:Class ;
              rdfs:subClassOf plsmo:PLSMO_C0034 ;
              chmo:IAO_0000115 """A quantity is the measurement of an observable property of a particular object, event, or physical system. A quantity is always associated with the context of measurement (i.e. the thing measured, the measured value, the accuracy of measurement, etc.) whereas the underlying quantity kind is independent of any particular measurement. Thus, length is a quantity kind while the height of a rocket is a specific quantity of length; its magnitude that may be expressed in meters, feet, inches, etc. Examples of physical quantities include physical constants, such as the speed of light in a vacuum, Planck's constant, the electric permittivity of free space, and the fine structure constant.

In other words, quantities are quantifiable aspects of the world, such as the duration of a movie, the distance between two points, velocity of a car, the pressure of the atmosphere, and a person's weight; and units are used to describe their numerical measure.

Many quantity kinds are related to each other by various physical laws, and as a result, the associated units of some quantity kinds can be expressed as products (or ratios) of powers of other quantity kinds (e.g., momentum is mass times velocity and velocity is defined as distance divided by time). In this way, some quantities can be calculated from other measured quantities using their associations to the quantity kinds in these expressions. These quantity kind relationships are also discussed in dimensional analysis. Those that cannot be so expressed can be regarded as \"fundamental\" in this sense.

A quantity is distinguished from a \"quantity kind\" in that the former carries a value and the latter is a type specifier.

See: https://qudt.org/schema/qudt/Quantity"""@en ;
              rdfs:label "Quantity"@en .


###  http://qudt.org/schema/qudt/QuantityKind
QUDT:QuantityKind rdf:type owl:Class ;
                  rdfs:subClassOf plsmo:PLSMO_C0034 ;
                  chmo:IAO_0000115 "A Quantity Kind is any observable property that can be measured and quantified numerically. Familiar examples include physical properties such as length, mass, time, force, energy, power, electric charge, etc. Less familiar examples include currency, interest rate, price to earning ratio, and information capacity."@en ;
                  rdfs:label "Quantity Kind"@en .


###  http://qudt.org/schema/qudt/QuantityValue
QUDT:QuantityValue rdf:type owl:Class ;
                   rdfs:subClassOf plsmo:PLSMO_C0034 ;
                   chmo:IAO_0000115 "A Quantity Value expresses the magnitude and kind of a quantity and is given by the product of a numerical value n and a unit of measure U. The number multiplying the unit is referred to as the numerical value of the quantity expressed in that unit. Refer to NIST SP 811 section 7 for more on quantity values."@en ;
                   rdfs:label "Quantity Value"@en .


###  https://plasma-mds.org/ontology/IC_Ontology/IC_0022
ic:IC_0022 rdf:type owl:Class ;
           owl:equivalentClass ic:IC_C0002 ,
                               [ owl:intersectionOf ( ic:IC_C0001
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty plsmo:PLSMO_R0010 ;
                                                        owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                        owl:onClass AFO:AFR_0001538
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty plsmo:PLSMO_R0010 ;
                                                        owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                        owl:onClass ic:IC_C0083
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty plsmo:PLSMO_R0010 ;
                                                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                        owl:onClass AFO:AFR_0001267
                                                      ]
                                                    ) ;
                                 rdf:type owl:Class
                               ] ;
           rdfs:subClassOf ic:IC_C0001 ;
           chmo:IAO_0000115 "Settings for the autosampler."@en ;
           rdfs:label "Autosampler Settings"@en .


