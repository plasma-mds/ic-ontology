ic:IC_A0002 rdf:type owl:DatatypeProperty ;
            rdfs:label "hasGuardColumnBrandName"@en .


###  https://plasma-mds.org/ontology/IC_Ontology/IC_A0003
ic:IC_A0003 rdf:type owl:DatatypeProperty ;
            rdfs:label "hasSeparationColumnBrandName"@en .


