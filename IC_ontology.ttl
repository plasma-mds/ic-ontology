<https://plasma-mds.org/ontology/IC_Ontology> rdf:type owl:Ontology ;
                                               owl:versionIRI <https://plasma-mds.org/ontology/IC_Ontology/0.5.0> ;
                                               dcterms:citation "" ;
                                               dcterms:created "2024-08-13" ;
                                               dcterms:creator "Ihda Chaeronny Siffa" ,
                                                               "Robert Wagner" ,
                                                               "https://orcid.org/0000-0002-2762-293X" ,
                                                               "https://orcid.org/0000-0002-4232-4543" ;
                                               dcterms:description "The ion chromatography ontology (IC-O) supports the standardized description of the laboratory and configuration context in ion chromatography. It contains the important terminology about necessary configurations for each device component and their necessary units." ;
                                               dcterms:license "https://creativecommons.org/licenses/by/4.0/" ;
                                               dcterms:title "Ion chromatography ontology (IC-O)" ;
                                               vann:preferredNamespacePrefix "ic" ;
                                               doap:bug-database "" ;
                                               owl:versionInfo "0.5.0" .

