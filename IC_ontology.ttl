#################################################################
#    Object Properties
#################################################################

###  http://qudt.org/schema/qudt/hasQuantityKind
QUDT:hasQuantityKind rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf owl:topObjectProperty ;
                     rdfs:domain QUDT:Quantity ;
                     rdfs:range QUDT:QuantityKind ;
                     rdfs:label "hasQuantityKind"@en .


###  http://qudt.org/schema/qudt/hasUnit
QUDT:hasUnit rdf:type owl:ObjectProperty ;
             owl:inverseOf plsmo:PLSMO_R0088 ;
             rdfs:domain QUDT:Quantity ;
             rdfs:range <https://qudt.org/schema/qudt/Unit> ;
             chmo:IAO_0000115 """This property relates a system of units with a unit of measure that is either:
    a) defined by the system,
    b) accepted for use by the system and is convertible to a unit of equivalent dimension that is defined by the system,
    c) a reference to the unit of measure of a quantity (variable or constant) of interest.

    Systems of units may distinguish between base and derived units. Base units are the units which measure the base quantities for the corresponding system of quantities. The base units are used to define units for all other quantities as products of powers of the base units. Such units are called derived units for the system.
This property relates a system of units with a unit of measure that is either a) defined by the system, or b) accepted for use by the system and is convertible to a unit of equivalent dimension that is defined by the system. Systems of units may distinguish between base and derived units. Base units are the units which measure the base quantities for the corresponding system of quantities. The base units are used to define units for all other quantities as products of powers of the base units. Such units are called derived units for the system.

See: https://qudt.org/schema/qudt/hasUnit"""@en ;
             rdfs:label "hasUnit"@en .


###  https://plasma-mds.org/ontology/plasma-o/PLSMO_R0007
plsmo:PLSMO_R0007 rdf:type owl:ObjectProperty ;
                  owl:inverseOf plsmo:PLSMO_R0042 ;
                  rdfs:domain plsmo:PLSMO_C0002 ;
                  rdfs:range chmo:CHMO_0001209 ,
                             chmo:CHMO_0001210 ;
                  rdfs:label "configurationOf"@en .


###  https://plasma-mds.org/ontology/plasma-o/PLSMO_R0010
plsmo:PLSMO_R0010 rdf:type owl:ObjectProperty ;
                  rdfs:domain plsmo:PLSMO_C0026 ;
                  rdfs:range plsmo:PLSMO_C0034 ;
                  rdfs:label "consistsOf"@en .


###  https://plasma-mds.org/ontology/plasma-o/PLSMO_R0042
plsmo:PLSMO_R0042 rdf:type owl:ObjectProperty ;
                  rdfs:domain chmo:CHMO_0001209 ,
                              chmo:CHMO_0001210 ,
                              plsmo:PLSMO_C0003 ;
                  rdfs:range plsmo:PLSMO_C0002 ;
                  chmo:IAO_0000115 "[Device] has [Configuration]"@en ;
                  rdfs:label "hasConfiguration"@en .


###  https://plasma-mds.org/ontology/plasma-o/PLSMO_R0088
plsmo:PLSMO_R0088 rdf:type owl:ObjectProperty ;
                  rdfs:domain <https://qudt.org/schema/qudt/Unit> ;
                  rdfs:range QUDT:QuantityKind ;
                  rdfs:label "unitOf"@en .


###  https://plasma-mds.org/ontology/plasma-o/PLSMO_R0101
plsmo:PLSMO_R0101 rdf:type owl:ObjectProperty ;
                  rdfs:domain plsmo:PLSMO_C0030 ;
                  rdfs:range plsmo:PLSMO_C0003 ;
                  rdfs:label "usesDevice"@en .


