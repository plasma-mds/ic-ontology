###  https://plasma-mds.org/ontology/IC_Ontology/IC_C0014
ic:IC_C0014 rdf:type owl:Class ;
            rdfs:subClassOf plsmo:PLSMO_C0002 ;
            chmo:IAO_0000115 "Part of the configuration, related to the used columns. The used columns defining the ion separation properties of the instrument."@en ;
            rdfs:label "Separation Configuration"@en .


###  https://plasma-mds.org/ontology/IC_Ontology/IC_C0015
ic:IC_C0015 rdf:type owl:Class ;
            owl:equivalentClass [ owl:intersectionOf ( ic:IC_C0014
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty plsmo:PLSMO_R0010 ;
                                                         owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                         owl:onClass AFO:AFR_0002029
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty plsmo:PLSMO_R0010 ;
                                                         owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                         owl:onClass AFO:AFR_0002561
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty plsmo:PLSMO_R0010 ;
                                                         owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                         owl:onClass ic:IC_C0089
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty plsmo:PLSMO_R0010 ;
                                                         owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                         owl:onClass ic:IC_C0091
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty ic:IC_A0002 ;
                                                         owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                         owl:onDataRange xsd:string
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ;
            rdfs:subClassOf ic:IC_C0014 ;
            chmo:IAO_0000115 """Guard columns protect the separator column from harmful sample components. They are positioned between the sample inlet and the separating columns.
------------------------------------------------------------------------------------------------------------------------
Definition derived from: ASTM Norm E1151-93 \"Standard Practice for Ion Chromatography Terms and Relationships"""@en ;
            rdfs:label "Guard Column"@en .


###  https://plasma-mds.org/ontology/IC_Ontology/IC_C0016
ic:IC_C0016 rdf:type owl:Class ;
            rdfs:subClassOf ic:IC_C0014 ;
            chmo:IAO_0000115 """Pre-columns are used to condition the mobile phase and are placed before the sample inlet.
------------------------------------------------------------------------------------------------------------------------
Definition derived from: ASTM Norm E1151-93 \"Standard Practice for Ion Chromatography Terms and Relationships\""""@en ;
            rdfs:label "Pre-column"@en .


###  https://plasma-mds.org/ontology/IC_Ontology/IC_C0017
ic:IC_C0017 rdf:type owl:Class ;
            owl:equivalentClass [ owl:intersectionOf ( ic:IC_C0014
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty plsmo:PLSMO_R0010 ;
                                                         owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                         owl:onClass AFO:AFR_0002029
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty plsmo:PLSMO_R0010 ;
                                                         owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                         owl:onClass AFO:AFR_0002561
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty plsmo:PLSMO_R0010 ;
                                                         owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                         owl:onClass ic:IC_C0088
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty plsmo:PLSMO_R0010 ;
                                                         owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                         owl:onClass ic:IC_C0090
                                                       ]
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty ic:IC_A0003 ;
                                                         owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                         owl:onDataRange xsd:string
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] ;
            rdfs:subClassOf ic:IC_C0014 ;
            chmo:IAO_0000115 """Separation columns are used to separate sample components. They are placed after the sample inlet and after guard columns (if used).
------------------------------------------------------------------------------------------------------------------------
Definition derived from: ASTM Norm E1151-93 \"Standard Practice for Ion Chromatography Terms and Relationships"""@en ;
            rdfs:label "Separation Column"@en .


###  https://plasma-mds.org/ontology/IC_Ontology/IC_C0018
ic:IC_C0018 rdf:type owl:Class ;
            rdfs:subClassOf plsmo:PLSMO_C0013 ;
            chmo:IAO_0000115 "Diagnostic methods used to measure properties of liquid samples. Examples chromatography such as liquid chromatography (LC), ion-exchange chromatography (IC) and spectroscopy such as  atomic absorption spectroscopy."@en ;
            rdfs:label "Liquid Diagnostics"@en .


###  https://plasma-mds.org/ontology/IC_Ontology/IC_C0019
ic:IC_C0019 rdf:type owl:Class ;
            rdfs:subClassOf chmo:CHMO_0001001 ;
            chmo:IAO_0000115 """A general term for several liquid column chromatographic techniques for the analysis of ionic or ionizable compounds.
------------------------------------------------------------------------------------------------------------------------
Source: ASTM Norm E1151-93 \"Standard Practice for Ion Chromatography Terms and Relationships\""""@en ;
            rdfs:label "Ion Chromatography"@en .


###  https://plasma-mds.org/ontology/IC_Ontology/IC_C0020
ic:IC_C0020 rdf:type owl:Class ;
            rdfs:subClassOf ic:IC_C0019 ;
            chmo:IAO_0000115 "A special type of ion chromatography based on the Gibbs-Donnan effect, caused by fixed ions of an anion/cation exchanger."@en ;
            rdfs:label "Donnan Exclusion Chromatography"@en .


###  https://plasma-mds.org/ontology/IC_Ontology/IC_C0023
ic:IC_C0023 rdf:type owl:Class ;
            rdfs:subClassOf ic:IC_C0014 ;
            chmo:IAO_0000115 """A suppressor column is used to selectively reduce the conductivity of the mobile phase to enhance the detection of the sample components. Suppressor columns are placed between the separation column and the detector.
------------------------------------------------------------------------------------------------------------------------
Definition derived from: ASTM Norm E1151-93 \"Standard Practice for Ion Chromatography Terms and Relationships"""@en ;
            rdfs:label "Suppressor Column"@en .


###  https://plasma-mds.org/ontology/IC_Ontology/IC_C0024
ic:IC_C0024 rdf:type owl:Class ;
            rdfs:subClassOf ic:IC_C0014 ;
            chmo:IAO_0000115 "A post column derivatization reactor is used in chromatography where the separated sample components leaving the separation column are mixed with a chemical reagent to form detectable products (e.g., colored or fluorescent compounds) before entering the detector."@en ;
            rdfs:label "Post Column Derivatization Reactor"@en .


###  https://plasma-mds.org/ontology/IC_Ontology/IC_C0025
ic:IC_C0025 rdf:type owl:Class ;
            chmo:IAO_0000115 "Terminology, which is not directly necessary to describe ion chromatography measurements but contribute to a better understanding of the measurement technology."@en ;
            rdfs:label "Related Terminology"@en .


###  https://plasma-mds.org/ontology/IC_Ontology/IC_C0026
ic:IC_C0026 rdf:type owl:Class ;
            rdfs:subClassOf ic:IC_C0025 ;
            chmo:IAO_0000115 "The suppressor is regenerated by rinsing the stationary phase with acid to provide protons for the subsequent suppression of eluent and analyte."@en ;
            rdfs:label "Chemically Regenerated Suppressor"@en .


###  https://plasma-mds.org/ontology/IC_Ontology/IC_C0027
ic:IC_C0027 rdf:type owl:Class ;
            owl:equivalentClass ic:IC_C0028 ;
            rdfs:subClassOf ic:IC_C0025 ;
            chmo:IAO_0000115 """Chemically suppressed ion chromatography describes a technique, where sample components are separated by a low capacity ion exchanger and detected conductimetrically. The detection of the sample components is enhanced by selctively suppressing the conductivity of the mobile phase through suppressor columns after the separation column.
------------------------------------------------------------------------------------------------------------------------
Definition derived from: ASTM Norm E1151-93 \"Standard Practice for Ion Chromatography Terms and Relationships"""@en ;
            rdfs:label "Chemically Suppressed Ion Chromatography"@en .


###  https://plasma-mds.org/ontology/IC_Ontology/IC_C0028
ic:IC_C0028 rdf:type owl:Class ;
            rdfs:subClassOf ic:IC_C0025 ;
            chmo:IAO_0000115 "The dual column ion chromatography technique is mostly chemically suppressed, as the usage of suppressor columns in front of a separation column is recommended to perform the ion chromatographic measurement. The usage of pre- or guard columns is optional."@en ;
            rdfs:label "Dual Column Ion Chromatography"@en .


###  https://plasma-mds.org/ontology/IC_Ontology/IC_C0029
ic:IC_C0029 rdf:type owl:Class ;
            rdfs:subClassOf ic:IC_C0025 ;
            chmo:IAO_0000115 "The solid phase of the suppressor is regenerated by an electrochemical process for continuous operation."@en ;
            rdfs:label "Electronically Regenerated Supressor"@en .


###  https://plasma-mds.org/ontology/IC_Ontology/IC_C0030
ic:IC_C0030 rdf:type owl:Class ;
            owl:equivalentClass ic:IC_C0031 ;
            rdfs:subClassOf ic:IC_C0025 ;
            chmo:IAO_0000115 """Electronically suppressed ion chromatography describes a technique, where sample components are separated by a low capacity ion exchanger and conductimetric detection. The mobile phase contains ions, which conductance differs from the measured sample ions, as the background signal of the mobile phase will be minimized by electronic suppression.
------------------------------------------------------------------------------------------------------------------------
Definition derived from: ASTM Norm E1151-93 \"Standard Practice for Ion Chromatography Terms and Relationships"""@en ;
            dcterms:references <http://purl.allotrope.org/ontologies/role#AFRL_0000011> ;
            rdfs:label "Electronically Suppressed Ion Chromatography"@en .


###  https://plasma-mds.org/ontology/IC_Ontology/IC_C0031
ic:IC_C0031 rdf:type owl:Class ;
            rdfs:subClassOf ic:IC_C0025 ;
            chmo:IAO_0000115 "A single column ion chromatography technique is mostly electronically suppressed, as only a separation column is need to perform the ion chromatographic measurement. The usage of pre- or guard columns is optional."@en ;
            rdfs:label "Single Column Ion Chromatography"@en .


###  https://plasma-mds.org/ontology/IC_Ontology/IC_C0032
ic:IC_C0032 rdf:type owl:Class ;
            rdfs:subClassOf ic:IC_C0025 ;
            chmo:IAO_0000115 "Peak caused by a unretained signals (e.g. pressure/conductivity changes upon sample injection or unretained sample components). This peak is close to thecolumn  void volume time."@en ;
            rdfs:label "Void Peak"@en .


